<main>
  <natambio>
    <!--
      Stereo DRC only, no subwoofer, no NAE.
      One FIR DRC filter per channel, loaded from a WAV file.
    -->

    <coeff>
      <name>DRC monitor left</name>
      <filename>~/filters/drc_monitor_left.wav</filename>
    </coeff>

    <coeff>
      <name>DRC monitor right</name>
      <filename>~/filters/drc_monitor_right.wav</filename>
    </coeff>

    <jack_input>
      <clientname>natambio</clientname>
      <port>
        <name>input_left</name>
        <destname>system:capture_1</destname>
      </port>
      <port>
        <name>input_right</name>
        <destname>system:capture_2</destname>
      </port>
    </jack_input>

    <jack_output>
      <port>
        <name>output_left</name>
        <destname>system:playback_1</destname>
      </port>
      <port>
        <name>output_right</name>
        <destname>system:playback_2</destname>
      </port>
    </jack_output>

    <convol>
      <name>DRC left</name>
      <coeff_name>DRC monitor left</coeff_name>
      <from_input>input_left</from_input>
      <to_output>output_left</to_output>
      <gain>0.0</gain>
    </convol>

    <convol>
      <name>DRC right</name>
      <coeff_name>DRC monitor right</coeff_name>
      <from_input>input_right</from_input>
      <to_output>output_right</to_output>
      <gain>0.0</gain>
    </convol>

  </natambio>
</main>
