<main>
  <natambio>
    <!--
      NAE front dipole (alpha) + mono subwoofer + stereo monitors,
      with DRC integrated via <convol_coeff> (derived coeffs).

      Each output path uses a single pre-convolved coeff combining
      the monitor DRC filter with the corresponding crossover half:

        HP DRC left/right  =  DRC monitor L/R  *  HP 120Hz  →  monitors
        LP DRC left/right  =  DRC monitor L/R  *  LP 120Hz  →  subwoofer

      DRC and crossover are thus applied in a single convolution pass
      per channel, reducing the number of convolvers required.
    -->

    <!-- Crossover at 120 Hz -->
    <low_and_high_filter>
      <frequency>120.0</frequency>
      <dB_octave>24</dB_octave>
      <gain>0</gain>
      <length>8192</length>
      <low_pass_coeff_name>LP 120Hz</low_pass_coeff_name>
      <high_pass_coeff_name>HP 120Hz</high_pass_coeff_name>
    </low_and_high_filter>

    <!-- DRC FIR filters, one per monitor -->
    <coeff>
      <name>DRC monitor left</name>
      <filename>~/filters/drc_monitor_left.wav</filename>
    </coeff>

    <coeff>
      <name>DRC monitor right</name>
      <filename>~/filters/drc_monitor_right.wav</filename>
    </coeff>

    <!--
      Derived coeffs: DRC convolved with each crossover half.
      <low_and_high_filter> coeffs are generated after all <coeff> blocks are
      read, so references to "HP 120Hz" / "LP 120Hz" are resolved at
      convolution-build time (see docs/README.CONFIG).
    -->
    <coeff>
      <name>HP DRC left</name>
      <convol_coeff>DRC monitor left</convol_coeff>
      <convol_coeff>HP 120Hz</convol_coeff>
      <length>16384</length>
    </coeff>

    <coeff>
      <name>HP DRC right</name>
      <convol_coeff>DRC monitor right</convol_coeff>
      <convol_coeff>HP 120Hz</convol_coeff>
      <length>16384</length>
    </coeff>

    <coeff>
      <name>LP DRC left</name>
      <convol_coeff>DRC monitor left</convol_coeff>
      <convol_coeff>LP 120Hz</convol_coeff>
      <length>16384</length>
    </coeff>

    <coeff>
      <name>LP DRC right</name>
      <convol_coeff>DRC monitor right</convol_coeff>
      <convol_coeff>LP 120Hz</convol_coeff>
      <length>16384</length>
    </coeff>

    <jack_input>
      <clientname>natambio</clientname>
      <port>
        <name>input_left</name>
        <destname>system:capture_1</destname>
      </port>
      <port>
        <name>input_right</name>
        <destname>system:capture_2</destname>
      </port>
    </jack_input>

    <jack_output>
      <port>
        <name>output_left</name>
        <destname>system:playback_1</destname>
      </port>
      <port>
        <name>output_right</name>
        <destname>system:playback_2</destname>
      </port>
      <port>
        <name>output_sub</name>
        <destname>system:playback_3</destname>
      </port>
    </jack_output>

    <!-- Front dipole: blends main component and ambience -->
    <nae>
      <name>front stereo dipole</name>
      <mode>alpha</mode>
      <front_gain>0.0</front_gain>
      <ambience_gain>3.0</ambience_gain>
      <input_left>input_left</input_left>
      <input_right>input_right</input_right>
      <output_left>nae_out_left</output_left>
      <output_right>nae_out_right</output_right>
    </nae>

    <!-- High-pass + DRC to monitors -->
    <convol>
      <name>HP DRC monitor left</name>
      <coeff_name>HP DRC left</coeff_name>
      <from_nae>nae_out_left</from_nae>
      <to_output>output_left</to_output>
      <gain>0.0</gain>
    </convol>

    <convol>
      <name>HP DRC monitor right</name>
      <coeff_name>HP DRC right</coeff_name>
      <from_nae>nae_out_right</from_nae>
      <to_output>output_right</to_output>
      <gain>0.0</gain>
    </convol>

    <!-- Low-pass + DRC to subwoofer (L and R sum into the same output, -3 dB each) -->
    <convol>
      <name>LP DRC sub left</name>
      <coeff_name>LP DRC left</coeff_name>
      <from_nae>nae_out_left</from_nae>
      <to_output>output_sub</to_output>
      <gain>-3.0</gain>
    </convol>

    <convol>
      <name>LP DRC sub right</name>
      <coeff_name>LP DRC right</coeff_name>
      <from_nae>nae_out_right</from_nae>
      <to_output>output_sub</to_output>
      <gain>-3.0</gain>
    </convol>

  </natambio>
</main>
