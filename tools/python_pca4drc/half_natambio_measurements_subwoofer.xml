<main>
  <natambio>
    <low_and_high_filter>
      <frequency>100.0</frequency>
      <dB_octave>24</dB_octave>
      <attenuation>0</attenuation>
      <length>8192</length>
      <low_pass_coeff_name>low pass filter</low_pass_coeff_name>
      <high_pass_coeff_name>high pass filter</high_pass_coeff_name>
    </low_and_high_filter>
    <jack_input> 
      <clientname>natambio</clientname>
      <priority>65</priority>
      <port>
	<name>front_input_left</name>
      </port>
      <port>
	<name>front_input_right</name>
      </port>      
      <port>
	<name>rear_input_left</name>
      </port>
      <port>
	<name>rear_input_right</name>
      </port> 
    </jack_input>
    <jack_output> 
      <port>
	<name>high_pass_front_output_left</name>
	<destname>system:playback_1</destname>
      </port>
      <port>
	<name>high_pass_front_output_right</name>
	<destname>system:playback_2</destname>
      </port>
      <port>
	<name>low_pass_front_output_left</name>
	<destname>system:playback_3</destname>
      </port>
      <port>
	<name>low_pass_front_output_right</name>
	<destname>system:playback_3</destname>
      </port>  
    </jack_output>
    <convol>
      <name>high_pass_front_left</name>
      <coeff_name>high_pass_filter</coeff_name>
      <from_input>front_input_left</from_input>
      <to_output>high_pass_front_output_left</to_output>
      <attenuation></attenuation>
      <delay></delay>
    </convol>
    <convol>
      <name>high_pass_front_right</name>
      <coeff_name>high_pass_filter</coeff_name>
      <from_input>front_input_right</from_input>
      <to_output>high_pass_front_output_right</to_output>
      <attenuation></attenuation>
      <delay></delay>
    </convol>
    <convol>
      <name>low_pass_front_left</name>
      <coeff_name>low_pass_filter</coeff_name>
      <from_input>front_input_left</from_input>
      <to_output>low_pass_front_output_left</to_output>
      <attenuation></attenuation>
      <delay></delay>
    </convol>
    <convol>
      <name>low_pass_front_right</name>
      <coeff_name>low_pass_filter</coeff_name>
      <from_input>front_input_right</from_input>
      <to_output>low_pass_front_output_right</to_output>
      <attenuation></attenuation>
      <delay></delay>
    </convol>
  </natambio>
</main>
